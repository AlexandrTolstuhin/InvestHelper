# Скопируйте в .env.local и заполните значениями из Firebase Console.
# Все переменные с префиксом VITE_ попадают в клиентский бандл — это нормально
# для Firebase web-конфига. Защита от злоупотреблений делается через
# allowlist в Firestore rules и Firebase App Check (см. firestore.rules).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# reCAPTCHA v3 site key для Firebase App Check
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Локально можно подставить debug-токен из Firebase Console (App Check → Apps → Manage debug tokens)
# для обхода reCAPTCHA на localhost. На проде НЕ задавать.
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=
